{
  "env": {
    "NODE_TLS_REJECT_UNAUTHORIZED": "0"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash",
      "WebSearch",
      "WebFetch(domain:127.0.0.1)",
      "mcp__stratio_data__*",
      "Bash(poetry *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pytest *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(bash *)",
      "Bash(source *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(cd *)",
      "Bash(jupyter nbconvert *)",
      "Bash(pandoc *)",
      "Bash(weasyprint *)",
      "Bash(pwd *)",
      "Bash(which *)",
      "Bash(curl *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(sed *)",
      "Bash(export *)",
      "Bash(xargs *)",
      "Bash(echo *)",
      "Bash(bash setup_env.sh *)",
      "WebFetch(domain:skills.sh)",
      "Bash(file:*)",
      "Bash(bash:*)",
      "Bash(test:*)",
      "Bash(ln:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "stratio_data"
  ]
}
