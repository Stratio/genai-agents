{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "mcp": {
    "stratio_gov": {
      "type": "remote",
      "url": "{env:MCP_GOV_URL}",
      "timeout": 600000,
      "headers": {
        "Authorization": "Bearer {env:MCP_GOV_API_KEY}",
        "X-API-Key": "{env:MCP_GOV_API_KEY}"
      }
    },
    "stratio_data": {
      "type": "remote",
      "url": "{env:MCP_SQL_URL}",
      "timeout": 90000,
      "headers": {
        "Authorization": "Bearer {env:MCP_SQL_API_KEY}",
        "X-API-Key": "{env:MCP_SQL_API_KEY}"
      }
    }
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "edit": "allow",
    "write": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "task": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "stratio_gov_*": "allow",
    "stratio_data_*": "allow",
    "*query_data": "deny",
    "*execute_sql": "deny",
    "*generate_sql": "deny",
    "*create_quality_rule": "deny",
    "*quality_rules_metadata": "deny",
    "*get_quality_rule_dimensions": "deny",
    "bash": {
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "tree *": "allow",
      "file *": "allow",
      "test *": "allow",
      "pwd": "allow",
      "which *": "allow",
      "git *": "allow",
      "gh *": "allow",
      "echo *": "allow"
    }
  }
}
